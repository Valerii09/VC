per (3+ \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 ){\line}Java / Kotlin / Spring / PostgreSQL / Docker / CI/CD{\line}{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1072 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1102  backend-\uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1099  \uc0\u1085 \uc0\u1072  Java (Spring Boot) \uc0\u1074  \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1105 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1072 \uc0\u1093 : REST API, \uc0\u1072 \uc0\u1089 \uc0\u1080 \uc0\u1085 \uc0\u1093 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072  \uc0\u1089  \uc0\u1088 \uc0\u1077 \uc0\u1083 \uc0\u1103 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1084 \uc0\u1080  \uc0\u1041 \uc0\u1044 .{\line}{\line}\uc0\u1054 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1086 \uc0\u1087 \uc0\u1099 \uc0\u1090  - \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1086 \uc0\u1088 \uc0\u1087 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084  \uc0\u1089  \uc0\u1073 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1096 \uc0\u1080 \uc0\u1084  \uc0\u1086 \uc0\u1073 \uc0\u1098 \uc0\u1105 \uc0\u1084 \uc0\u1086 \uc0\u1084  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093 : \uc0\u1086 \uc0\u1087 \uc0\u1090 \uc0\u1080 \uc0\u1084 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  SQL \uc0\u1080  ORM, \uc0\u1091 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1091 \uc0\u1079 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1090 , \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1073 \uc0\u1086 \uc0\u1088  \uc0\u1080  \uc0\u1091 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  production-\uc0\u1080 \uc0\u1085 \uc0\u1094 \uc0\u1080 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074  (\uc0\u1074 \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1072 \uc0\u1103  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1073 \uc0\u1083 \uc0\u1077 \uc0\u1084 \uc0\u1099  \uc0\u1084 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080  \uc0\u1080  \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1082 \uc0\u1091 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1091 \uc0\u1087 \uc0\u1072 ).{\line}{\line}\uc0\u1056 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1089  \uc0\u1073 \uc0\u1088 \uc0\u1086 \uc0\u1082 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1080  \uc0\u1089 \uc0\u1086 \uc0\u1086 \uc0\u1073 \uc0\u1097 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081  (JMS/ActiveMQ), \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1103 \uc0\u1102  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1093 \uc0\u1086 \uc0\u1076 \uc0\u1099  event-driven \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099 . \uc0\u1059 \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1091 \uc0\u1102  \uc0\u1074  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1080  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099  \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1087 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1080  \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1073 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099 , \uc0\u1074 \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1072 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1091  \uc0\u1073 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1086 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1086 \uc0\u1073 \uc0\u1077 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1082 \uc0\u1086 \uc0\u1073 \uc0\u1077 \uc0\u1079 \uc0\u1086 \uc0\u1087 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 .{\line}{\line}\uc0\u1056 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1091  \uc0\u1087 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1086  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095 \uc0\u1072 \uc0\u1084  Jira \uc0\u1085 \uc0\u1072  \uc0\u1073 \uc0\u1072 \uc0\u1079 \uc0\u1077  RAG: \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1091 , \uc0\u1074 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1080 \uc0\u1083  ETL-\uc0\u1087 \uc0\u1072 \uc0\u1081 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1081 \uc0\u1085 , \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102  \uc0\u1089  LLM (LangChain, Ollama), \uc0\u1074 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1093 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1083 \uc0\u1080 \uc0\u1097 \uc0\u1077  \uc0\u1080  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1091  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 .{\line}{\line}\uc0\u1045 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1086 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080  Android-\uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081  (Kotlin){\line}GitHub: https://github.com/Valerii09}\cell\row\pard}