}\cell\pard\intbl\itap1{\fs50\b \uc0\u1058 \uc0\u1088 \uc0\u1091 \uc0\u1092 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074  \uc0\u1042 \uc0\u1072 \uc0\u1083 \uc0\u1077 \uc0\u1088 \uc0\u1080 \uc0\u1081  \uc0\u1040 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1089 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1080 \uc0\u1095 }\par\pard\intbl\itap1\sl260{\fs18 Male, 25\uc0\u160 years, born on 22 March 2001}\par\pard\intbl\sl260{\fs18 \par +7\uc0\u160 (914)\uc0\u160 0049005\par {{\field{\*\fldinst HYPERLINK "mailto:valiera.trufanov.2001@gmail.com"}{\fldrslt\ul valiera.trufanov.2001@gmail.com}}} {\cf1\emdash  preferred means of communication}}\par\pard\intbl\sl260{\fs18 \par Reside in: Moscow\par Citizenship: Russia, work permit at: Russia\par Ready to relocate, ready for business trips}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 Desired position and salary}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa100\sl280{\fs24\b Java developer}\pard\intbl\itap1\sl260{\fs18 \par{Specializations:  }\par\li300{\uc0\u8212   Programmer, developer}\par\par\pard\intbl\itap1\sl260{\fs18 Employment type: full time\par Work format: at the employer's location, remote, hybrid\par \lineDesired travel time to work: any}}\cell \row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 Work experience \emdash 4 years}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 May 2024 \emdash  till now\line 2 years}\cell\pard\intbl\itap1\par\cell\pard\intbl\itap1\sl280{\fs24\b Mirapolis}\par\pard\intbl\itap1\sl260{\fs18\cf1 Moscow, www.mirapolis.ru}\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 Java developer\par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080  (Java backend){\line}{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1072 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1083  backend \uc0\u1082 \uc0\u1086 \uc0\u1088 \uc0\u1087 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1086 \uc0\u1081  LMS-\uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080  \uc0\u1073 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1096 \uc0\u1080 \uc0\u1093  \uc0\u1086 \uc0\u1073 \uc0\u1098 \uc0\u1105 \uc0\u1084 \uc0\u1086 \uc0\u1074  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  (>100k \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1077 \uc0\u1081 ), \uc0\u1074 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1080 \uc0\u1074  \uc0\u1073 \uc0\u1077 \uc0\u1079 \uc0\u1086 \uc0\u1087 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1091 \uc0\u1102  \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1091 \uc0\u1102  \uc0\u1079 \uc0\u1072 \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1079 \uc0\u1082 \uc0\u1091  \uc0\u1080  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1080 \uc0\u1084 \uc0\u1080 \uc0\u1085 \uc0\u1075  \uc0\u1074 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1074 \uc0\u1099 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1082 \uc0\u1080 , \uc0\u1095 \uc0\u1090 \uc0\u1086  \uc0\u1091 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1083 \uc0\u1086  \uc0\u1086 \uc0\u1096 \uc0\u1080 \uc0\u1073 \uc0\u1082 \uc0\u1080  \uc0\u1087 \uc0\u1072 \uc0\u1084 \uc0\u1103 \uc0\u1090 \uc0\u1080  (DataSetLimitException) \uc0\u1080  \uc0\u1087 \uc0\u1086 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1083 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1072 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1100  \uc0\u1074 \uc0\u1099 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1082 \uc0\u1080  >100k \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1077 \uc0\u1081  \uc0\u1073 \uc0\u1077 \uc0\u1079  \uc0\u1076 \uc0\u1077 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 {\line}\uc0\u1054 \uc0\u1087 \uc0\u1090 \uc0\u1080 \uc0\u1084 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  SQL-\uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1099  \uc0\u1080  ORM-\uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1082 \uc0\u1091 , \uc0\u1089 \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1074  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103  \uc0\u1074 \uc0\u1099 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1105 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1074 \uc0\u1099 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1082  \uc0\u1076 \uc0\u1086  50%.{\line}\uc0\u1059 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1083  production-\uc0\u1086 \uc0\u1096 \uc0\u1080 \uc0\u1073 \uc0\u1082 \uc0\u1080 , \uc0\u1074 \uc0\u1099 \uc0\u1079 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1087 \uc0\u1072 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1083 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1077 \uc0\u1081  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1074 , \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1074 \uc0\u1105 \uc0\u1083  \uc0\u1073 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1086 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1090  \uc0\u1085 \uc0\u1072  thread-safe \uc0\u1093 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080  \uc0\u1072 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1086 \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 .{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1072 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1083  REST API \uc0\u1089  \uc0\u1091 \uc0\u1095 \uc0\u1105 \uc0\u1090 \uc0\u1086 \uc0\u1084  \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1077 \uc0\u1074 \uc0\u1086 \uc0\u1081  \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1080  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1091 \uc0\u1087 \uc0\u1072 , \uc0\u1092 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1096 \uc0\u1080 \uc0\u1088 \uc0\u1103 \uc0\u1077 \uc0\u1084 \uc0\u1086 \uc0\u1081  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099  \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 .{\line}\uc0\u1056 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1084 \uc0\u1077 \uc0\u1093 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1084  \uc0\u1076 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1084 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1096 \uc0\u1080 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1091 \uc0\u1087 \uc0\u1072  (RolePermissionsService), \uc0\u1087 \uc0\u1086 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1074  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1099 \uc0\u1084  \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1083 \uc0\u1103 \uc0\u1084  \uc0\u1073 \uc0\u1077 \uc0\u1079 \uc0\u1086 \uc0\u1087 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1086  \uc0\u1076 \uc0\u1086 \uc0\u1073 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1103 \uc0\u1090 \uc0\u1100  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1092 \uc0\u1080 \uc0\u1083 \uc0\u1080  \uc0\u1073 \uc0\u1077 \uc0\u1079  \uc0\u1080 \uc0\u1079 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  core.{\line}\uc0\u1059 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1083  \uc0\u1089 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1073 \uc0\u1083 \uc0\u1077 \uc0\u1084 \uc0\u1099  ORM (LazyInitializationException, \uc0\u1080 \uc0\u1079 \uc0\u1073 \uc0\u1099 \uc0\u1090 \uc0\u1086 \uc0\u1095 \uc0\u1085 \uc0\u1099 \uc0\u1077  JOIN-\uc0\u1099 , \uc0\u1084 \uc0\u1091 \uc0\u1083 \uc0\u1100 \uc0\u1090 \uc0\u1080 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1103 ), \uc0\u1089 \uc0\u1085 \uc0\u1080 \uc0\u1078 \uc0\u1072 \uc0\u1103  \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1085 \uc0\u1072 \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1079 \uc0\u1082 \uc0\u1091  \uc0\u1085 \uc0\u1072  \uc0\u1041 \uc0\u1044 .{\line}\uc0\u1042 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1080 \uc0\u1083  \uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  (Logback, MDC), \uc0\u1091 \uc0\u1083 \uc0\u1091 \uc0\u1095 \uc0\u1096 \uc0\u1080 \uc0\u1074  \uc0\u1076 \uc0\u1080 \uc0\u1072 \uc0\u1075 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1091  \uc0\u1080  \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1091  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1074 .{\line}\uc0\u1056 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1089  Apache Solr: \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1081 \uc0\u1082 \uc0\u1072  \uc0\u1089 \uc0\u1093 \uc0\u1077 \uc0\u1084 , \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080 \uc0\u1085 \uc0\u1076 \uc0\u1077 \uc0\u1082 \uc0\u1089 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 , \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079  \uc0\u1079 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1081 .{\line}{\line}\uc0\u1050 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1072  \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1105 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099 {\line}{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1095 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1089 \uc0\u1086 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1078 \uc0\u1076 \uc0\u1072 \uc0\u1083  \uc0\u1082 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1091 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 (internal / external \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099 ) {\line}\uc0\u1044 \uc0\u1080 \uc0\u1072 \uc0\u1075 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1091 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1083  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1073 \uc0\u1083 \uc0\u1077 \uc0\u1084 \uc0\u1099  \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1085 \uc0\u1093 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1084 \uc0\u1077 \uc0\u1078 \uc0\u1076 \uc0\u1091  \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1080  (INSERT/UPDATE \uc0\u1074  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1079 \uc0\u1072 \uc0\u1082 \uc0\u1094 \uc0\u1080 \uc0\u1103 \uc0\u1093 , FK-\uc0\u1079 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 , routing \uc0\u1087 \uc0\u1086  \uc0\u1090 \uc0\u1080 \uc0\u1087 \uc0\u1072 \uc0\u1084  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093 ).{\line}\uc0\u1044 \uc0\u1080 \uc0\u1072 \uc0\u1075 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1091 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1083  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1073 \uc0\u1083 \uc0\u1077 \uc0\u1084 \uc0\u1099  \uc0\u1074  \uc0\u1072 \uc0\u1089 \uc0\u1080 \uc0\u1085 \uc0\u1093 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1077  (JMS, ActiveMQ): \uc0\u1087 \uc0\u1086 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1089 \uc0\u1086 \uc0\u1086 \uc0\u1073 \uc0\u1097 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081 , \uc0\u1079 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  consumer-\uc0\u1089 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1081 , \uc0\u1085 \uc0\u1072 \uc0\u1088 \uc0\u1091 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1086 \uc0\u1088 \uc0\u1103 \uc0\u1076 \uc0\u1082 \uc0\u1072  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080 {\line}{\line}CI/CD \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1072 {\line}{\line}\uc0\u1056 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1089  Jenkins: \uc0\u1076 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1072 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1083  CI/CD \uc0\u1087 \uc0\u1072 \uc0\u1081 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1099  (Jenkins, Groovy, Shell), \uc0\u1074 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1080 \uc0\u1083  \uc0\u1092 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1080 \uc0\u1079 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081  \uc0\u1080  \uc0\u1073 \uc0\u1077 \uc0\u1079 \uc0\u1086 \uc0\u1087 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1089 \uc0\u1083 \uc0\u1080 \uc0\u1103 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1074 \uc0\u1077 \uc0\u1090 \uc0\u1086 \uc0\u1082 , \uc0\u1089 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1074  \uc0\u1088 \uc0\u1080 \uc0\u1089 \uc0\u1082  \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1092 \uc0\u1083 \uc0\u1080 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1087 \uc0\u1088 \uc0\u1080  \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1083 \uc0\u1080 \uc0\u1103 \uc0\u1085 \uc0\u1080 \uc0\u1080 {\line}\uc0\u1048 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  Docker \uc0\u1080  docker-compose: \uc0\u1089 \uc0\u1086 \uc0\u1079 \uc0\u1076 \uc0\u1072 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1099  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081 , \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1089 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1082 \uc0\u1091  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1091 \uc0\u1089 \uc0\u1082  \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1091 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081  (Java + PostgreSQL + Tomcat + Solr).{\line}\uc0\u1053 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1084 \uc0\u1080 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1073 \uc0\u1072 \uc0\u1079  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1095 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1079  Liquibase: \uc0\u1089 \uc0\u1086 \uc0\u1079 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  changelog-\uc0\u1092 \uc0\u1072 \uc0\u1081 \uc0\u1083 \uc0\u1086 \uc0\u1074 , \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072 \uc0\u1090 \uc0\u1099  \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1082 \uc0\u1072  \uc0\u1089 \uc0\u1093 \uc0\u1077 \uc0\u1084 .{\line}\uc0\u1056 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1089  Apache Tomcat (\uc0\u1091 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072 , \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1081 \uc0\u1082 \uc0\u1072 , \uc0\u1076 \uc0\u1080 \uc0\u1072 \uc0\u1075 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1073 \uc0\u1083 \uc0\u1077 \uc0\u1084  \uc0\u1087 \uc0\u1088 \uc0\u1080  \uc0\u1076 \uc0\u1077 \uc0\u1087 \uc0\u1083 \uc0\u1086 \uc0\u1077 ).{\line}{\line}\uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 : RAG-\uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1072  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1087 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1072  Jira-\uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095 {\line}{\line}\uc0\u1056 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  end-to-end \uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1086 \uc0\u1090  \uc0\u1079 \uc0\u1072 \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1079 \uc0\u1082 \uc0\u1080  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1076 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1092 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1072 {\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  RAG-\uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1091  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1074 \uc0\u1085 \uc0\u1091 \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1077 \uc0\u1075 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1086  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095 \uc0\u1072 \uc0\u1084  Jira.{\line}\uc0\u1055 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1083  ETL-\uc0\u1087 \uc0\u1072 \uc0\u1081 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1081 \uc0\u1085  \uc0\u1079 \uc0\u1072 \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1079 \uc0\u1082 \uc0\u1080  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1080 \uc0\u1079  Jira REST API \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1076 \uc0\u1077 \uc0\u1082 \uc0\u1089 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1074  Supabase Vector Store.{\line}\uc0\u1048 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1088 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  LangChain + Ollama \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1075 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1086 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1085 \uc0\u1072  \uc0\u1086 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1077  \uc0\u1074 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1072 .{\line}\uc0\u1048 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  Qwen 2.5 VL \uc0\u1095 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1079  OpenRouter API \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1084 \uc0\u1091 \uc0\u1083 \uc0\u1100 \uc0\u1090 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1074  (\uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1089 \uc0\u1090  + \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 ).{\line}\uc0\u1044 \uc0\u1086 \uc0\u1073 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1083  OCR \uc0\u1080  \uc0\u1087 \uc0\u1072 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1085 \uc0\u1075  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074  (PDF/DOCX) \uc0\u1089  \uc0\u1087 \uc0\u1086 \uc0\u1084 \uc0\u1086 \uc0\u1097 \uc0\u1100 \uc0\u1102  Python.{\line}\uc0\u1040 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1074 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1082 \uc0\u1091  \uc0\u1080  \uc0\u1086 \uc0\u1073 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1095 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1079  n8n cloud.{\line}{\line}\uc0\u1058 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080 :{\line}Java 8/17, Spring Framework 6, Spring Boot, Hibernate, PostgreSQL,{\line}Liquibase, Jenkins, Groovy, Docker, Apache Tomcat, Apache Solr 7, LDAP,{\line}LangChain, Ollama, Supabase Vector Store, n8n (cloud),{\line}Qwen 2.5 VL, OpenRouter API, Python (OCR, PDF Parser),{\line}Jira REST API, concurrency}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 February 2023 \emdash  April 2024\line 1 year 3 months}\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b Artlab}\par\pard\intbl\itap1\sl260{\fs18\cf1 Novosibirsk}\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 Android developer\par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1072 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1078 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1085 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1099 \uc0\u1077  Android-\uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1085 \uc0\u1072  Kotlin \uc0\u1089  \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \uc0\u1084  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1099  MVVM \uc0\u1080  Single Activity Architecture.{\line}\uc0\u1059 \uc0\u1083 \uc0\u1091 \uc0\u1095 \uc0\u1096 \uc0\u1080 \uc0\u1083  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 -\uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1074 \uc0\u1079 \uc0\u1072 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1080 \uc0\u1077  \uc0\u1085 \uc0\u1072  \uc0\u1091 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1085 \uc0\u1077  TCP/IP: \uc0\u1088 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1076 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1084 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1091 \uc0\u1102  \uc0\u1073 \uc0\u1091 \uc0\u1092 \uc0\u1077 \uc0\u1088 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102  \uc0\u1087 \uc0\u1072 \uc0\u1082 \uc0\u1077 \uc0\u1090 \uc0\u1086 \uc0\u1074 , \uc0\u1087 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1089 \uc0\u1080 \uc0\u1083  \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1073 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  handshake \uc0\u1080  \uc0\u1085 \uc0\u1072 \uc0\u1095 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1089 \uc0\u1086 \uc0\u1086 \uc0\u1073 \uc0\u1097 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081 .{\line}\uc0\u1048 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1088 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  REST API \uc0\u1095 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1079  Retrofit, \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1072 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1072 \uc0\u1089 \uc0\u1080 \uc0\u1085 \uc0\u1093 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1099  \uc0\u1089  \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \uc0\u1084  Coroutines \uc0\u1080  LiveData.{\line}\uc0\u1053 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1083  CI/CD \uc0\u1087 \uc0\u1072 \uc0\u1081 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1081 \uc0\u1085  \uc0\u1074  GitLab CI: \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103  \uc0\u1089 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1082 \uc0\u1072 , \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1091 \uc0\u1089 \uc0\u1082  unit/instrumented \uc0\u1090 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1088 \uc0\u1077 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1099 .{\line}\uc0\u1048 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1088 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  Firebase (Remote Config, Authentication, Firestore, Crashlytics) \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1080 , A/B-\uc0\u1090 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1080  \uc0\u1073 \uc0\u1077 \uc0\u1079 \uc0\u1086 \uc0\u1087 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 .{\line}\uc0\u1054 \uc0\u1087 \uc0\u1090 \uc0\u1080 \uc0\u1084 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1089 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1082 \uc0\u1091  \uc0\u1095 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1079  Gradle: \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1081 \uc0\u1082 \uc0\u1072  \uc0\u1079 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1081 , \uc0\u1082 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  flavor, \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1100 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1080  \uc0\u1089 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1082 \uc0\u1080 .{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1072 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1083  UI \uc0\u1087 \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1085 \uc0\u1094 \uc0\u1080 \uc0\u1087 \uc0\u1072 \uc0\u1084  Material Design 3: \uc0\u1082 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1082 \uc0\u1086 \uc0\u1087 \uc0\u1086 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1099 , \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1087 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099 , \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1078 \uc0\u1082 \uc0\u1072  \uc0\u1090 \uc0\u1105 \uc0\u1084 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099 .{\line}\uc0\u1042 \uc0\u1099 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1103 \uc0\u1083  \uc0\u1083 \uc0\u1086 \uc0\u1082 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102  \uc0\u1085 \uc0\u1072  \uc0\u1085 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1082 \uc0\u1086  \uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 \uc0\u1086 \uc0\u1074 , \uc0\u1074 \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1072 \uc0\u1103  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1078 \uc0\u1082 \uc0\u1091  RTL-\uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1092 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1082 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102  \uc0\u1088 \uc0\u1077 \uc0\u1089 \uc0\u1091 \uc0\u1088 \uc0\u1089 \uc0\u1086 \uc0\u1074 .{\line}\uc0\u1054 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1095 \uc0\u1072 \uc0\u1083  \uc0\u1079 \uc0\u1072  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1091  \uc0\u1088 \uc0\u1077 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1087 \uc0\u1091 \uc0\u1073 \uc0\u1083 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102  \uc0\u1074  Google Play Market (\uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1099  APK/AAB, \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1100  \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1072 \uc0\u1084 \uc0\u1080 , \uc0\u1089 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1083 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1085 \uc0\u1075 \uc0\u1086 \uc0\u1074 ).{\line}{\line}\uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1083  code review, \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1072 \uc0\u1083  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102 , \uc0\u1091 \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1074  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095  \uc0\u1080  \uc0\u1088 \uc0\u1077 \uc0\u1092 \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1085 \uc0\u1075 \uc0\u1077  \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1083 \uc0\u1077 \uc0\u1081 , \uc0\u1091 \uc0\u1083 \uc0\u1091 \uc0\u1095 \uc0\u1096 \uc0\u1080 \uc0\u1074  \uc0\u1095 \uc0\u1080 \uc0\u1090 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1080  \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1073 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1082 \uc0\u1086 \uc0\u1076 \uc0\u1072 .{\line}{\line}\uc0\u1058 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080 : Kotlin, Android SDK, Retrofit, Coroutines, LiveData, Firebase, GitLab CI, Gradle, Google Play Console, TCP/IP, MVVM, Material Design.}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 October 2021 \emdash  June 2022\line 9 months}\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1058 \uc0\u1086 \uc0\u1084 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103  \uc0\u1101 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  , \uc0\u1054 \uc0\u1054 \uc0\u1054  \uc0\u1053 \uc0\u1055 \uc0\u1055 }\par\pard\intbl\itap1\sl260{\fs18\cf1 www.npptec.ru}\par{\fs18 Electronics, Tool Engineering, Household Appliances, Computers and Office Equipment}\par\li300{{\fs18 \uc0\u8226  Computer, Optical, Control and Measurement Technology, Radio and Electronics, Automatics (Promotion, Wholesale)}}\par\li300{{\fs18 \uc0\u8226  Computer, Optical, Control and Measurement Technology, Radio and Electronics, Automatics (Assembly, Maintenance, Repair)}}\par\li300{{\fs18 \uc0\u8226  Computer, Optical, Control and Measurement Technology, Radio and Electronics, Automatics (Manufacturing)}}\par \pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1057 \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1082  IT \uc0\u1086 \uc0\u1090 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1072 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1080  \uc0\u1074 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1080 \uc0\u1083  \uc0\u1074 \uc0\u1085 \uc0\u1091 \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1080 \uc0\u1077  IT-\uc0\u1088 \uc0\u1077 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1099 : \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1072  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1073 \uc0\u1077 \uc0\u1079 \uc0\u1086 \uc0\u1087 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 , \uc0\u1087 \uc0\u1086 \uc0\u1088 \uc0\u1103 \uc0\u1076 \uc0\u1086 \uc0\u1082  \uc0\u1088 \uc0\u1077 \uc0\u1079 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1082 \uc0\u1086 \uc0\u1087 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 , \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1083 \uc0\u1072  \uc0\u1091 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1091 \uc0\u1095 \uc0\u1105 \uc0\u1090 \uc0\u1085 \uc0\u1099 \uc0\u1084 \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1103 \uc0\u1084 \uc0\u1080  \uc0\u1080  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1091 \uc0\u1087 \uc0\u1072 \uc0\u1084 \uc0\u1080 .{\line}{\line}\uc0\u1042 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1080 \uc0\u1083  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1091  \uc0\u1091 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095 \uc0\u1072 \uc0\u1084 \uc0\u1080  \uc0\u1080  \uc0\u1073 \uc0\u1072 \uc0\u1075 -\uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1082 \uc0\u1080 \uc0\u1085 \uc0\u1075 \uc0\u1072  YouTrack: \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1081 \uc0\u1082 \uc0\u1072 , \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1089  \uc0\u1082 \uc0\u1086 \uc0\u1088 \uc0\u1087 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1087 \uc0\u1086 \uc0\u1095 \uc0\u1090 \uc0\u1086 \uc0\u1081 , \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1080  \uc0\u1080  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095 .{\line}{\line}\uc0\u1040 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1099  IT-\uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1078 \uc0\u1082 \uc0\u1080 : \uc0\u1074 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1080 \uc0\u1083  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1091  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1094 \uc0\u1080 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 , \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1083  \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1100  SLA \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102  \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1077 \uc0\u1090 \uc0\u1086 \uc0\u1074 .{\line}{\line}\uc0\u1040 \uc0\u1076 \uc0\u1084 \uc0\u1080 \uc0\u1085 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1082 \uc0\u1086 \uc0\u1088 \uc0\u1087 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1091 \uc0\u1102  \uc0\u1089 \uc0\u1077 \uc0\u1090 \uc0\u1100 : \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1081 \uc0\u1082 \uc0\u1072  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1095 \uc0\u1080 \uc0\u1093  \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1094 \uc0\u1080 \uc0\u1081 , \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1078 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1081 , \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1074 \uc0\u1105 \uc0\u1088 \uc0\u1090 \uc0\u1099 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080  \uc0\u1089 \uc0\u1086 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1078 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1086 \uc0\u1074  \uc0\u1085 \uc0\u1072  \uc0\u1073 \uc0\u1072 \uc0\u1079 \uc0\u1077  Linux .{\line}{\line}\uc0\u1054 \uc0\u1073 \uc0\u1077 \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1095 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1073 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1091 \uc0\u1102  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1091 \uc0\u1102  \uc0\u1073 \uc0\u1077 \uc0\u1079 \uc0\u1086 \uc0\u1087 \uc0\u1072 \uc0\u1089 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 : \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1100  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1091 \uc0\u1087 \uc0\u1072  (Active Directory), \uc0\u1072 \uc0\u1085 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1080 \uc0\u1088 \uc0\u1091 \uc0\u1089 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1097 \uc0\u1080 \uc0\u1090 \uc0\u1072 , \uc0\u1084 \uc0\u1086 \uc0\u1085 \uc0\u1080 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1085 \uc0\u1075  \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080  \uc0\u1074  \uc0\u1089 \uc0\u1077 \uc0\u1090 \uc0\u1080 .{\line}{\line}\uc0\u1054 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1091  \uc0\u1088 \uc0\u1077 \uc0\u1079 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1082 \uc0\u1086 \uc0\u1087 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1080  \uc0\u1074 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093 : \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1081 \uc0\u1082 \uc0\u1072  \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1073 \uc0\u1101 \uc0\u1082 \uc0\u1072 \uc0\u1087 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1082 \uc0\u1072  \uc0\u1074 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081 .{\line}{\line}\uc0\u1058 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080 : Windows Server, Active Directory, Linux (Ubuntu, CentOS), YouTrack, Office 365, bash, TCP/IP, DHCP, DNS, TeamViewer, VNC.}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 Education}\cell\row\trowd\cellx9638\pard\intbl\itap1\sl220{\fs22Bachelor}\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2023\line Bachelor}\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1053 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1080 \uc0\u1089 \uc0\u1089 \uc0\u1083 \uc0\u1077 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1058 \uc0\u1086 \uc0\u1084 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090 , \uc0\u1058 \uc0\u1086 \uc0\u1084 \uc0\u1089 \uc0\u1082 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1048 \uc0\u1064 \uc0\u1048 \uc0\u1058 \uc0\u1056 , \uc0